# ─── Database (Neon – free tier: neon.tech) ───────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── Google OAuth (console.cloud.google.com) ──────────────────────────────────
# 1. New project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 2. Add redirect URI: https://your-app.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Vercel Blob (free 500 MB) ────────────────────────────────────────────────
# Dashboard → Storage → Create → Blob → connect to this project (auto-filled)
BLOB_READ_WRITE_TOKEN=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
