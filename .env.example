# ─── Database (Neon – free tier: neon.tech) ───────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Must match your deployed URL exactly (used to build the OAuth callback URI)
AUTH_URL=

# ─── Google OAuth (console.cloud.google.com) ──────────────────────────────────
# 1. New project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 2. Add authorized redirect URI: https://your-app-url.com/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app-url.com
